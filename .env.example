# Supabase — copie para .env.local e preencha com os valores do seu projeto.
# Encontre em: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Strava — crie o app em https://www.strava.com/settings/api
# "Authorization Callback Domain" deve ser o domínio do site (sem https://),
# ex: bsb-run.vercel.app
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
